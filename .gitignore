# SIEMhunter .gitignore — secrets and generated artifacts must never be committed

# =============================================================================
# SECRETS (CRITICAL — never commit credentials or key material)
# =============================================================================
.env
.env.*
*.pem
*.key
*.p12
*.pfx
secrets/
docker-secrets/
# Note: *.crt is allowed for CA bundles; exclude private key files only
*.key.crt

# =============================================================================
# PYTHON
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
venv/
.venv/
env/
.env/
pip-wheel-metadata/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
*.pyc

# =============================================================================
# TERRAFORM / IaC
# =============================================================================
.terraform/
*.tfstate
*.tfstate.*
# Keep .terraform.lock.hcl (dependency lock file — should be committed)
crash.log
# *.tfvars — comment out to allow non-secret tfvars; uncomment to block all
# *.tfvars

# =============================================================================
# DOCKER (local overrides should not be committed)
# =============================================================================
docker-compose.override.yml
# .dockerignore should be committed — do not ignore it

# =============================================================================
# DATA / LOCAL VOLUMES (never commit ClickHouse data or local event stores)
# =============================================================================
data/
volumes/
*.db
*.sqlite
clickhouse-data/

# =============================================================================
# ML MODELS (large binary artifacts — managed separately, not in git)
# =============================================================================
*.pkl
models/*.pkl
models/*.joblib
models/*.h5
models/*.bin
models/*.pt
models/*.onnx

# =============================================================================
# SIGMA COMPILED RULES (generated artifacts — source is in rules/local/ and rules/sigma/)
# =============================================================================
rules/compiled/

# =============================================================================
# CI ARTIFACTS (generated by pipeline; not for version control)
# =============================================================================
*.sbom.json
sbom/
trivy-results.json
grype-results.json
gitleaks-report.json

# =============================================================================
# LOGS
# =============================================================================
*.log
logs/

# =============================================================================
# EDITOR / OS
# =============================================================================
# VS Code: keep extensions.json, ignore user settings
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# JUPYTER (if used for ML development)
# =============================================================================
.ipynb_checkpoints/
*.ipynb

# =============================================================================
# NODE (if a thin frontend is added later)
# =============================================================================
node_modules/
npm-debug.log*
yarn-error.log

# =============================================================================
# CLAUDE CODE / ORCHESTRATOR (local tooling — not project source)
# =============================================================================
.claude/
.orchestrator/

# =============================================================================
# MISC
# =============================================================================
*.bak
*.tmp
*.orig
